# Database (optional - uses PGLite if not set)
# DATABASE_URL=postgresql://user:password@localhost:5432/roomchat
# Railway: use ${{Postgres.DATABASE_URL}} variable reference

# Google OAuth (required for room creation)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Application origin URL
# Railway: set to your Railway service URL (e.g. https://roomchat-production.up.railway.app)
ORIGIN=http://localhost:5173

# Cookie signing secret (HMAC-SHA256)
# Required in production. In dev, a random secret is auto-generated if not set.
# COOKIE_SECRET=

# PostgreSQL SSL mode (disable | no-verify | prefer | require)
# Default: prefer. Railway internal DB does not require SSL (use "disable").
# DB_SSL_MODE=prefer
