# Database (optional - uses PGLite if not set)
# DATABASE_URL=postgresql://user:password@localhost:5432/roomchat
# Render: DATABASE_URL is automatically set via render.yaml Blueprint

# Google OAuth (required for room creation)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Application origin URL
# Render: set to your Render service URL (e.g. https://roomchat.onrender.com)
ORIGIN=http://localhost:5173

# Cookie signing secret (HMAC-SHA256)
# Required in production. In dev, a random secret is auto-generated if not set.
# Render: auto-generated via render.yaml
# COOKIE_SECRET=

# PostgreSQL SSL mode (disable | no-verify | prefer | require)
# Default: prefer. Render requires "no-verify" for managed databases.
# DB_SSL_MODE=prefer
